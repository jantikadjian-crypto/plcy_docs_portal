{
  "name": "plcy-docs-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/apply-audience.mjs && node scripts/build-search-index.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/apply-audience.mjs && node scripts/build-search-index.mjs",
    "build": "next build",
    "start": "next start",
    "search:index": "node scripts/build-search-index.mjs",
    "new-doc": "node scripts/new-doc.mjs",
    "dev:internal": "node scripts/apply-audience.mjs --internal && node scripts/build-search-index.mjs && next dev",
    "build:internal": "node scripts/apply-audience.mjs --internal && node scripts/build-search-index.mjs && next build"
  },
  "dependencies": {
    "next": "^13.5.6",
    "nextra": "^2.13.4",
    "nextra-theme-docs": "^2.13.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
